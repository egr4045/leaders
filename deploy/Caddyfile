# HTTPS обязателен: доступ к камере работает только в защищённом контексте.
# Let's Encrypt получается автоматически для mygame-quiz.ru.

mygame-quiz.ru, www.mygame-quiz.ru {
	encode gzip

	# realtime-сокеты игры → Node-сервер на хосте
	handle /socket.io/* {
		reverse_proxy host.docker.internal:3000
	}

	# REST API игры (health и будущие ручки)
	handle_path /api/* {
		reverse_proxy host.docker.internal:3000
	}

	# сгенерированные ассеты (озвучка диктора, картинки);
	# /assets/* трогать нельзя — там бандл Vite из статики
	handle /media/* {
		reverse_proxy host.docker.internal:3000
	}

	# LiveKit signal/WebSocket
	handle_path /livekit/* {
		reverse_proxy livekit:7880
	}

	# хэшированный бандл Vite — кэшировать можно вечно (имя меняется при сборке)
	handle /assets/* {
		root * /srv/www
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# статика клиента (vite build); index.html не кэшируем —
	# иначе браузер держит ссылки на старый бандл и ловит 404/белый экран
	handle {
		root * /srv/www
		header Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}
